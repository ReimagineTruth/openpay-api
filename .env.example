# Pi Network API Configuration
PI_API_KEY="your_pi_api_key_here"
PI_VALIDATION_KEY="your_pi_validation_key_here"
VITE_PI_SANDBOX="false"

# Supabase Configuration
VITE_SUPABASE_PROJECT_ID="your_supabase_project_id"
VITE_SUPABASE_PUBLISHABLE_KEY="your_supabase_publishable_key"
VITE_SUPABASE_URL="https://your-project.supabase.co"

# Solana Pay Configuration
VITE_SOLANA_PAY_MERCHANT_WALLET="your_solana_merchant_wallet_address"
VITE_SOLANA_PAY_MERCHANT_NAME="OpenPay"

# OpenRouter AI Configuration (Required for AI features)
VITE_OPENROUTER_API_KEY="sk-or-v1-your_openrouter_api_key_here"

# Note: 
# 1. Copy this file to .env and fill in your actual values
# 2. Get OpenRouter API key from https://openrouter.ai/keys
# 3. The .env file is automatically ignored by git for security
# 4. Restart your development server after changing environment variables
